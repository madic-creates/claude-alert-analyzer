{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  onboarding: false,
  requireConfig: 'ignored',
  extends: [
    'config:recommended',
  ],
  'pre-commit': {
    enabled: true,
  },
  assignees: [
    'madic-creates',
  ],
  repositories: [
    'madic-creates/claude-alert-analyzer',
  ],
  gitAuthor: 'Renovate Bot <bot@renovateapp.com>',
  semanticCommits: 'enabled',
  semanticCommitType: 'chore',
  semanticCommitScope: 'deps',
  // Run `go mod tidy` as part of each Go update branch so the pushed go.sum is
  // already canonical. Without this, Renovate only touches the bumped module's
  // hashes and leaves stale entries behind — which the CI `tidy` job (and thus
  // the release gate) would then reject. Opt-in because tidy can touch lines
  // unrelated to the bump; here that trade-off is exactly what we want.
  postUpdateOptions: [
    'gomodTidy',
  ],
  prConcurrentLimit: 0,
  prHourlyLimit: 0,
  platform: 'github',
  automerge: true,
  automergeType: 'branch',
  ignoreTests: true,
  major: {
    automerge: false,
  },
  minor: {
    automerge: true,
  },
  patch: {
    automerge: true,
  },
  packageRules: [
    {
      // Keep k8s.io/* libraries on the same minor version — mixing them breaks the build.
      matchManagers: [
        'gomod',
      ],
      matchPackageNames: [
        'k8s.io/api',
        'k8s.io/apimachinery',
        'k8s.io/client-go',
      ],
      groupName: 'k8s.io',
    },
  ],
  minimumReleaseAge: '5 days',
  // Apply the age check only when the datasource provides a release timestamp.
  // Without this, Docker images that don't expose per-tag timestamps (e.g. many
  // GHCR-hosted images) get stuck with pendingChecks=true and are filtered out
  // by internalChecksFilter: 'strict', so no update PR is ever opened.
  minimumReleaseAgeBehaviour: 'timestamp-optional',
  internalChecksFilter: 'strict',
}
